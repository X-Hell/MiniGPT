{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Flask API Backend",
      "runtimeExecutable": "python",
      "runtimeArgs": ["website_api/app.py"],
      "port": 8000
    },
    {
      "name": "FastAPI Backend",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["website_api.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "port": 8000
    },
    {
      "name": "Vite React Frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "website", "run", "dev"],
      "port": 5173
    }
  ]
}
